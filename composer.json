{
    "name": "elvesora/soryxa-laravel",
    "version": "1.0.0",
    "description": "Laravel SDK for the Soryxa email validation API",
    "keywords": ["soryxa", "email", "validation", "laravel"],
    "license": "MIT",
    "authors": [
        {
            "name": "Elvesora",
            "email": "team@elvesora.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Elvesora\\Soryxa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Elvesora\\Soryxa\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Elvesora\\Soryxa\\SoryxaServiceProvider"
            ],
            "aliases": {
                "Soryxa": "Elvesora\\Soryxa\\Facades\\Soryxa"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
